{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "CS2 Demo Manager",
  "version": "0.1.0",
  "identifier": "local.cs2.demo.manager",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [{ "title": "CS2 Demo Manager", "width": 1280, "height": 820 }],
    "security": { "csp": null }
  },
  "bundle": {
    "active": true,
    "targets": ["msi", "nsis"],
    "icon": ["icons/icon.ico"],
    "resources": ["../analyzer"]
  }
}
